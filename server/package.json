{
  "name": "csi-manakkala-server",
  "version": "1.0.0",
  "type": "commonjs",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc",
    "vercel-build": "tsc",
    "migrate": "node dist/db/migrate.js",
    "db:generate": "npx drizzle-kit generate",
    "db:migrate": "npx drizzle-kit migrate",
    "db:push": "npx drizzle-kit push",
    "db:pull": "npx drizzle-kit introspect",
    "db:studio": "npx drizzle-kit studio",
    "db:check": "npx drizzle-kit check"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.10.1",
    "backblaze-b2": "^1.7.1",
    "bcrypt": "^5.1.1",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "drizzle-orm": "^0.45.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.0.2",
    "node-cache": "^5.1.2",
    "pg": "^8.16.3",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/backblaze-b2": "^1.5.6",
    "@types/bcrypt": "^5.0.2",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.10.6",
    "@types/pg": "^8.18.0",
    "drizzle-kit": "^0.31.9",
    "drizzle-zod": "^0.8.3",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
